Lab 6: Resource Quota
apiVersion: v1
kind: ResourceQuota
metadata:
  name: quota
spec:
  hard:
    pods: "5"
    requests.cpu: "2"
    requests.memory: 2Gi
oc apply -f quota.yaml
oc describe quota


Lab 7: Limit Range
apiVersion: v1
kind: LimitRange
metadata:
  name: limits
spec:
  limits:
  - default:
      cpu: 500m
      memory: 512Mi
oc apply -f limit.yaml


Lab 8: Disable Self-Provisioning
oc get clusterrolebinding self-provisioners
oc adm policy remove-cluster-role-from-group self-provisioner system:authenticated:oauth


