# Service Account:
===

mkdir ocp-gcp/
cd ocp-gcp/

gcloud iam service-accounts create ocp-installer \
  --display-name="OpenShift Installer"

PROJECT_ID=$(gcloud config get-value project)
SA_EMAIL="ocp-installer@${PROJECT_ID}.iam.gserviceaccount.com"

gcloud projects add-iam-policy-binding $PROJECT_ID \
  --member="serviceAccount:${SA_EMAIL}" \
  --role="roles/owner"

gcloud iam service-accounts keys create gcp-ocp-key.json \
  --iam-account="${SA_EMAIL}"

export GOOGLE_APPLICATION_CREDENTIALS=gcp-ocp-key.json

gcloud auth activate-service-account --key-file=$GOOGLE_APPLICATION_CREDENTIALS

