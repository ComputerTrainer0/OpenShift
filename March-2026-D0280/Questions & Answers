apiVersion: apps/v1
kind: Deployment
metadata:
  name: zone-preferred-demo
spec:
  replicas: 3
  selector:
    matchLabels:
      app: zone-preferred-demo
  template:
    metadata:
      labels:
        app: zone-preferred-demo
    spec:
      affinity:
        nodeAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            preference:
              matchExpressions:
              - key: topology.kubernetes.io/zone
                operator: In
                values:
                - us-east-1c
      containers:
      - name: nginx
