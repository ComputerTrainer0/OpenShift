Real working example using the exact hostname label

apiVersion: v1
kind: Pod
metadata:
  name: host-demo
spec:
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
        - matchExpressions:
          - key: kubernetes.io/hostname
            operator: In
            values:
            - ip-10-0-65-134.ec2.internal
  containers:
  - name: nginx
    image: 35.153.133.45:5000/nginx


