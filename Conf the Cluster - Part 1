-- Hands on starts --
vi template.yaml

apiVersion: template.openshift.io/v1
kind: Template
metadata:
  name: simple-nginx-template
parameters:
- name: APP_NAME
  value: simple-nginx
- name: IMAGE
  value: quay.io/nginx/nginx-unprivileged
- name: CONTAINER_PORT
  value: "8080"
objects:
- apiVersion: apps/v1
  kind: Deployment
  metadata:
    name: ${APP_NAME}
  spec:
    replicas: 1
    selector:
      matchLabels:
        app: ${APP_NAME}
    template:
      metadata:
        labels:
          app: ${APP_NAME}
      spec:
        containers:
        - name: nginx
          image: ${IMAGE}
          ports:
          - containerPort: ${{CONTAINER_PORT}}
- apiVersion: v1
  kind: Service
  metadata:
    name: ${APP_NAME}
  spec:
    selector:
      app: ${APP_NAME}
    ports:
    - name: http
      port: 8080
      targetPort: ${{CONTAINER_PORT}}
- apiVersion: route.openshift.io/v1
  kind: Route
  metadata:
    name: ${APP_NAME}
  spec:
    to:
      kind: Service
      name: ${APP_NAME}
    port:
      targetPort: http

#:wq

#--EOF--

oc process -f template.yaml

oc process -f template.yaml | oc apply -f -

oc get pods
oc get svc
oc get route


#---override them with custom parameters

oc process -f simple-template.yaml \
  -p APP_NAME=my-nginx \
  -p IMAGE=nginxinc/nginx-unprivileged \
  -p CONTAINER_PORT=8080 | oc apply -f -


