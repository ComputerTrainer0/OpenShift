vi create-students-namespaces.sh
#!/bin/bash
set -e

STUDENT_COUNT=18

for i in $(seq 1 $STUDENT_COUNT); do
  USER="student$i"
  NS="student-n$i"

  echo "Creating project ${NS}..."
  oc new-project "${NS}" >/dev/null 2>&1 || echo "Project ${NS} already exists"

  echo "Granting admin to ${USER} on ${NS}..."
  oc policy add-role-to-user admin "${USER}" -n "${NS}"

  echo "Done: ${USER} -> ${NS}"
  echo "----------------------------------"
done

EOF

