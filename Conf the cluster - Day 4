Kustomize:

Folder Structure:

  kustomize-demo/
  ├── base
  │   ├── deployment.yaml
  │   ├── service.yaml
  │   └── kustomization.yaml
  └── overlays
      ├── dev
      │   └── kustomization.yaml
      └── prod
          └── kustomization.yaml

Task:

Create a base with nginx deployment and service
Create a dev overlay with:
  prefix dev-
  label env=dev
  1 replica
Create a prod overlay with:
  prefix prod-
  label env=prod
  3 replicas
Apply both and verify resources

Explanation:
base = common reusable config
overlay = environment-specific customization
same app can be deployed differently for:
  dev
  test
  prod

Hands on:

mkdir -p ~/kustomize-demo/base
mkdir -p ~/kustomize-demo/overlays/dev
mkdir -p ~/kustomize-demo/overlays/prod
cd ~/kustomize-demo

cat > ~/kustomize-demo/base/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx
spec:
  replicas: 1
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
      - name: nginx
        image: 35.153.133.45:5000/nginx-unprivileged
        ports:
        - containerPort: 8080
EOF

cat > ~/kustomize-demo/base/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: nginx
spec:
  selector:
    app: nginx
  ports:
  - port: 80
    targetPort: 8080
EOF

#Adding details to kutomization
cat > ~/kustomize-demo/base/kustomization.yaml
resources:
- deployment.yaml
- service.yaml

#Testing the base:
oc kustomize base

cat > ~/kustomize-demo/overlays/dev/kustomization.yaml
resources:
- ../../base

namePrefix: dev-

commonLabels:
  env: dev

replicas:
- name: nginx
  count: 1

images:
- name: nginx
  newName: 35.153.133.45:5000/nginx-unprivileged
  newTag: "1.25"

EOF

oc kustomize overlays/dev
oc apply -k overlays/dev

cat > ~/kustomize-demo/overlays/prod/kustomization.yaml
resources:
- ../../base

namePrefix: prod-

commonLabels:
  env: prod

replicas:
- name: nginx
  count: 3

images:
- name: nginx
  newName: 35.153.133.45:5000/nginx-unprivileged
  newTag: "1.27"

oc kustomize overlays/prod
oc apply -k overlays/prod

Verify:
oc get deployment
oc get pods
oc get svc

Delete:
oc delete -k overlays/dev
oc delete -k overlays/prod


